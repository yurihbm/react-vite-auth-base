{
	"name": "react-vite-auth-base",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc -b && vite build",
		"build-storybook": "storybook build",
		"dev": "vite",
		"format": "prettier --write .",
		"i18n": "i18next-cli extract && i18next-cli types",
		"i18n:watch": "i18next-cli extract --watch",
		"i18n:types": "i18next-cli types",
		"lint": "eslint .",
		"prepare": "node .husky/install.mjs",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"test": "vitest run",
		"test:ci": "vitest run --bail 1",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@phosphor-icons/react": "^2.1.10",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-query": "^5.100.5",
		"@tanstack/react-query-devtools": "^5.100.5",
		"@tanstack/react-router": "^1.168.24",
		"@tanstack/react-router-devtools": "^1.166.13",
		"i18next": "^26.0.8",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^3.0.6",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-i18next": "^17.0.4",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@rolldown/plugin-babel": "^0.2.3",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-vitest": "^10.3.5",
		"@storybook/react-vite": "^10.3.5",
		"@tanstack/eslint-plugin-query": "^5.100.5",
		"@tanstack/router-plugin": "^1.167.27",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/babel__core": "^7.20.5",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser-playwright": "4.1.5",
		"@vitest/coverage-v8": "4.1.5",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-storybook": "^10.3.5",
		"globals": "^17.5.0",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"i18next-cli": "^1.56.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"storybook": "^10.3.5",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{css,json,md,yaml,yml}": [
			"prettier --write"
		]
	}
}
